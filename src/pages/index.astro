---
import Base from '../layouts/Base.astro';
import Filters from '../components/Filters.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');

allEvents.sort((a, b) => a.data.start_date.localeCompare(b.data.start_date));

const todayStr = new Date().toISOString().slice(0, 10);
const upcoming = allEvents.filter(e => e.data.start_date >= todayStr);
const past     = allEvents.filter(e => e.data.start_date <  todayStr);

function formatDate(iso: string): string {
  return new Date(iso + 'T00:00:00Z').toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC',
  });
}

function formatDateRange(start: string, end: string): string {
  const s = formatDate(start);
  return start === end ? s : `${s} – ${formatDate(end)}`;
}

// Build-time event index for client-side filtering
const eventIndex = allEvents.map(e => ({
  id: e.id,
  title: e.data.title,
  city: e.data.city,
  month: e.data.start_date.slice(0, 7),
  topics: e.data.topics,
  format: e.data.format,
  price: e.data.price,
  venue: e.data.venue ?? '',
  summary: e.data.summary,
}));

// Generate filter facets from the collection
const cities   = [...new Set(allEvents.map(e => e.data.city))].sort();
const months   = [...new Set(allEvents.map(e => e.data.start_date.slice(0, 7)))].sort();
const topics   = [...new Set(allEvents.flatMap(e => e.data.topics))].sort();
const formats  = [...new Set(allEvents.map(e => e.data.format))].sort();

// Escape < to < so the JSON is safe inside a <script> element
const eventIndexJson = JSON.stringify(eventIndex).replace(/</g, '\\u003c');
---

<Base title="UK Open Source Events">
  <h1>UK Open Source Events</h1>
  <p class="lead">Upcoming open source conferences and meetups across the United Kingdom.</p>

  <script type="application/json" id="event-index" set:html={eventIndexJson}></script>

  <Filters cities={cities} months={months} topics={topics} formats={formats} />

  {upcoming.length === 0 ? (
    <p class="empty-state">No upcoming events at the moment. Check back soon.</p>
  ) : (
    <ol id="upcoming-events" class="event-list">
      {upcoming.map(event => (
        <li data-event-id={event.id}>
          <article class="event-card">
            <h2 class="event-title">
              <a href={`/events/${event.id}/`}>{event.data.title}</a>
            </h2>
            <p class="event-meta">
              <time datetime={event.data.start_date}>{formatDateRange(event.data.start_date, event.data.end_date)}</time>
              <span class="event-meta__sep" aria-hidden="true">·</span>
              {event.data.city}
            </p>
            <p class="event-badges">
              <span class={`badge badge--${event.data.format}`}>{event.data.format}</span>
              <span class={`badge badge--${event.data.price}`}>{event.data.price}</span>
            </p>
            <p class="event-summary">{event.data.summary}</p>
          </article>
        </li>
      ))}
    </ol>
  )}

  {past.length > 0 && (
    <details class="past-events">
      <summary>Past events ({past.length})</summary>
      <ol class="event-list">
        {past.map(event => (
          <li>
            <article class="event-card event-card--past">
              <h2 class="event-title">
                <a href={`/events/${event.id}/`}>{event.data.title}</a>
              </h2>
              <p class="event-meta">
                <time datetime={event.data.start_date}>{formatDateRange(event.data.start_date, event.data.end_date)}</time>
                <span class="event-meta__sep" aria-hidden="true">·</span>
                {event.data.city}
              </p>
              <p class="event-badges">
                <span class={`badge badge--${event.data.format}`}>{event.data.format}</span>
                <span class={`badge badge--${event.data.price}`}>{event.data.price}</span>
              </p>
            </article>
          </li>
        ))}
      </ol>
    </details>
  )}
</Base>
