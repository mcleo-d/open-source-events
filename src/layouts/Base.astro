---
import '../styles/global.css';

interface Props { title: string; }
const { title } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Set theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <header>
      <a href="/" class="site-title">UK Open Source Events</a>
      <button id="theme-toggle" class="theme-toggle" aria-pressed="false" aria-label="Enable dark theme">
        Dark
      </button>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p><a href="https://github.com/mcleo-d/open-source-events">View on GitHub</a></p>
    </footer>
    <script>
      import '../scripts/theme.ts';
    </script>
  </body>
</html>
