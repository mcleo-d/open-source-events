---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/global.css" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="/" class="site-title">UK Open Source Events</a>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        <a href="https://github.com/mcleo-d/open-source-events">View on GitHub</a>
      </p>
    </footer>
  </body>
</html>
